{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "sourceMap": true,
    "lib": ["es6", "dom"],
    "outDir": "plugin/js",
    "jsx": "react",
    "moduleResolution": "node",
    "rootDir": "./js-src",
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strictNullChecks": true
  },
  "exclude": [
    "node_modules",
  ]
}
